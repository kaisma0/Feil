<UserControl
    x:Class="Feil.Views.Pages.SettingsPage"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="using:Feil.ViewModels.Pages"
    x:DataType="vm:SettingsPageViewModel"
    Background="Transparent"
    mc:Ignorable="d">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel
            MaxWidth="680"
            Margin="28,24"
            Spacing="20">

            <!--  Page header  -->
            <StackPanel Spacing="3">
                <TextBlock Classes="page-title" Text="Settings" />
                <TextBlock Classes="page-subtitle" Text="Configure Feil to your liking" />
            </StackPanel>

            <!--
                ══════════════════════════════════════════════════
                DOWNLOAD SECTION
                ══════════════════════════════════════════════════
            -->
            <Border Classes="feil-card">
                <StackPanel Spacing="20">

                    <StackPanel Orientation="Horizontal" Spacing="12">
                        <Border Classes="section-icon">
                            <PathIcon
                                Width="16"
                                Height="16"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Data="M19 9h-4V3H9v6H5l7 7 7-7zM5 18v2h14v-2H5z" />
                        </Border>
                        <TextBlock
                            VerticalAlignment="Center"
                            FontSize="15"
                            FontWeight="SemiBold"
                            Foreground="{DynamicResource FeilTextPrimary}"
                            Text="Download" />
                    </StackPanel>

                    <Separator Classes="feil-divider" />

                    <!--  Install path  -->
                    <StackPanel Spacing="8">
                        <StackPanel Spacing="2">
                            <TextBlock
                                FontSize="13"
                                FontWeight="SemiBold"
                                Foreground="{DynamicResource FeilTextPrimary}"
                                Text="Install location" />
                            <TextBlock
                                FontSize="11"
                                Foreground="{DynamicResource FeilTextSecondary}"
                                Text="Where completed downloads will be placed" />
                        </StackPanel>
                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                            <TextBox
                                Grid.Column="0"
                                FontSize="13"
                                PlaceholderText="~/Games/Feil"
                                Text="{Binding InstallPath}" />
                            <Button
                                Grid.Column="1"
                                Classes="feil-ghost"
                                Click="OnBrowseInstallPathClick"
                                ToolTip.Tip="Browse…">
                                <PathIcon
                                    Width="14"
                                    Height="14"
                                    Data="M10 4H4c-1.1 0-1.99.9-1.99 2L2 18c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V8c0-1.1-.9-2-2-2h-8l-2-2z" />
                            </Button>
                        </Grid>
                    </StackPanel>

                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="16">
                        <StackPanel Grid.Column="0" Spacing="2">
                            <TextBlock
                                FontSize="13"
                                FontWeight="SemiBold"
                                Foreground="{DynamicResource FeilTextPrimary}"
                                Text="Skip Depot Selection Dialog" />
                            <TextBlock
                                FontSize="11"
                                Foreground="{DynamicResource FeilTextSecondary}"
                                Text="Automatically download all Depots without prompting (OS filtering still applies)" />
                        </StackPanel>
                        <ToggleSwitch
                            Grid.Column="1"
                            VerticalAlignment="Center"
                            IsChecked="{Binding SkipDepotSelection}"
                            OffContent=""
                            OnContent="" />
                    </Grid>

                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="16">
                        <StackPanel Grid.Column="0" Spacing="2">
                            <TextBlock
                                FontSize="13"
                                FontWeight="SemiBold"
                                Foreground="{DynamicResource FeilTextPrimary}"
                                Text="Auto-apply Steamstub" />
                            <TextBlock
                                FontSize="11"
                                Foreground="{DynamicResource FeilTextSecondary}"
                                TextWrapping="Wrap"
                                Text="After each successful install, scan for Steam DRM protected EXEs and automatically bypass it" />
                        </StackPanel>
                        <ToggleSwitch
                            Grid.Column="1"
                            VerticalAlignment="Center"
                            IsChecked="{Binding AutoApplySteamstub}"
                            OffContent=""
                            OnContent="" />
                    </Grid>

                </StackPanel>
            </Border>

            <!--
                ══════════════════════════════════════════════════
                STARTUP SECTION
                ══════════════════════════════════════════════════
            -->
            <Border Classes="feil-card">
                <StackPanel Spacing="20">

                    <StackPanel Orientation="Horizontal" Spacing="12">
                        <Border Classes="section-icon">
                            <PathIcon
                                Width="16"
                                Height="16"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Data="M11.99 2C6.47 2 2 6.48 2 12s4.47 10 9.99 10C17.52 22 22 17.52 22 12S17.52 2 11.99 2zM12 20c-4.42 0-8-3.58-8-8s3.58-8 8-8 8 3.58 8 8-3.58 8-8 8zm.5-13H11v6l5.25 3.15.75-1.23-4.5-2.67V7z" />
                        </Border>
                        <TextBlock
                            VerticalAlignment="Center"
                            FontSize="15"
                            FontWeight="SemiBold"
                            Foreground="{DynamicResource FeilTextPrimary}"
                            Text="Startup" />
                    </StackPanel>

                    <Separator Classes="feil-divider" />

                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="16">
                        <StackPanel Grid.Column="0" Spacing="2">
                            <TextBlock
                                FontSize="13"
                                FontWeight="SemiBold"
                                Foreground="{DynamicResource FeilTextPrimary}"
                                Text="Launch on system startup" />
                            <TextBlock
                                FontSize="11"
                                Foreground="{DynamicResource FeilTextSecondary}"
                                Text="Start Feil automatically when you log in" />
                        </StackPanel>
                        <ToggleSwitch
                            Grid.Column="1"
                            VerticalAlignment="Center"
                            IsChecked="{Binding LaunchOnStartup}"
                            OffContent=""
                            OnContent="" />
                    </Grid>

                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="16">
                        <StackPanel Grid.Column="0" Spacing="2">
                            <TextBlock
                                FontSize="13"
                                FontWeight="SemiBold"
                                Foreground="{DynamicResource FeilTextPrimary}"
                                Text="Start minimised" />
                            <TextBlock
                                FontSize="11"
                                Foreground="{DynamicResource FeilTextSecondary}"
                                Text="Launch to system tray without showing the window" />
                        </StackPanel>
                        <ToggleSwitch
                            Grid.Column="1"
                            VerticalAlignment="Center"
                            IsChecked="{Binding StartMinimised}"
                            OffContent=""
                            OnContent="" />
                    </Grid>

                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="16">
                        <StackPanel Grid.Column="0" Spacing="2">
                            <TextBlock
                                FontSize="13"
                                FontWeight="SemiBold"
                                Foreground="{DynamicResource FeilTextPrimary}"
                                Text="Auto-resume interrupted downloads" />
                            <TextBlock
                                FontSize="11"
                                Foreground="{DynamicResource FeilTextSecondary}"
                                Text="Pick up in-progress jobs where they left off on next launch" />
                        </StackPanel>
                        <ToggleSwitch
                            Grid.Column="1"
                            VerticalAlignment="Center"
                            IsChecked="{Binding AutoResumeOnStart}"
                            OffContent=""
                            OnContent="" />
                    </Grid>

                </StackPanel>
            </Border>

            <!--
                ══════════════════════════════════════════════════
                STEAM SECTION
                ══════════════════════════════════════════════════
            -->
            <Border Classes="feil-card">
                <StackPanel Spacing="20">

                    <StackPanel Orientation="Horizontal" Spacing="12">
                        <Border Classes="section-icon">
                            <PathIcon
                                Width="16"
                                Height="16"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Data="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 14.5v-9l6 4.5-6 4.5z" />
                        </Border>
                        <TextBlock
                            VerticalAlignment="Center"
                            FontSize="15"
                            FontWeight="SemiBold"
                            Foreground="{DynamicResource FeilTextPrimary}"
                            Text="Steam" />
                    </StackPanel>

                    <Separator Classes="feil-divider" />

                    <StackPanel Spacing="8">
                        <StackPanel Spacing="2">
                            <TextBlock
                                FontSize="13"
                                FontWeight="SemiBold"
                                Foreground="{DynamicResource FeilTextPrimary}"
                                Text="Account ID override for Achievements" />
                            <TextBlock
                                FontSize="11"
                                Foreground="{DynamicResource FeilTextSecondary}"
                                Text="Use this Account ID for stats files instead of the logged-in account. Leave empty to use the signed-in account."
                                TextWrapping="Wrap" />
                        </StackPanel>
                        <TextBox
                            MaxWidth="260"
                            HorizontalAlignment="Left"
                            FontSize="13"
                            PlaceholderText="e.g. 22202"
                            Text="{Binding SteamAccountId}" />
                    </StackPanel>

                </StackPanel>
            </Border>

            <!--
                ══════════════════════════════════════════════════
                UPDATES SECTION
                ══════════════════════════════════════════════════
            -->
            <Border Classes="feil-card">
                <StackPanel Spacing="20">

                    <StackPanel Orientation="Horizontal" Spacing="12">
                        <Border Classes="section-icon">
                            <PathIcon
                                Width="16"
                                Height="16"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Data="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm1 15h-2v-2h2v2zm0-4h-2V7h2v6z" />
                        </Border>
                        <TextBlock
                            VerticalAlignment="Center"
                            FontSize="15"
                            FontWeight="SemiBold"
                            Foreground="{DynamicResource FeilTextPrimary}"
                            Text="Updates" />
                    </StackPanel>

                    <Separator Classes="feil-divider" />

                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="16">
                        <StackPanel
                            Grid.Column="0"
                            VerticalAlignment="Center"
                            Spacing="2">
                            <TextBlock
                                FontSize="13"
                                FontWeight="SemiBold"
                                Foreground="{DynamicResource FeilTextPrimary}"
                                Text="{Binding UpdateStatusMessage}" />
                            <ProgressBar
                                Height="4"
                                Margin="0,8,0,0"
                                IsIndeterminate="{Binding IsCheckingForUpdates}"
                                IsVisible="{Binding ShowUpdateProgress}"
                                Value="{Binding UpdateProgress}" />
                        </StackPanel>
                        <Button
                            Grid.Column="1"
                            VerticalAlignment="Center"
                            Classes="feil-accent"
                            Command="{Binding CheckForUpdatesCommand}">
                            <TextBlock
                                FontSize="13"
                                FontWeight="SemiBold"
                                Text="{Binding UpdateButtonText}" />
                        </Button>
                    </Grid>

                </StackPanel>
            </Border>

            <!--
                ══════════════════════════════════════════════════
                ACTION BUTTONS
                ══════════════════════════════════════════════════
            -->
            <Grid
                VerticalAlignment="Center"
                ColumnDefinitions="*,Auto"
                ColumnSpacing="16">

                <!--  Status messages  -->
                <StackPanel
                    Grid.Column="0"
                    VerticalAlignment="Center"
                    Spacing="2">
                    <TextBlock
                        FontSize="12"
                        Foreground="{DynamicResource FeilSuccessBrush}"
                        IsVisible="{Binding ShowSaveSuccess}"
                        Text="{Binding SaveStatusMessage}"
                        TextWrapping="Wrap" />
                    <TextBlock
                        FontSize="12"
                        Foreground="{DynamicResource FeilWarningBrush}"
                        IsVisible="{Binding ShowSaveWarning}"
                        Text="{Binding SaveStatusMessage}"
                        TextWrapping="Wrap" />
                    <TextBlock
                        FontSize="12"
                        Foreground="{DynamicResource FeilDangerBrush}"
                        IsVisible="{Binding ShowSaveError}"
                        Text="{Binding SaveStatusMessage}"
                        TextWrapping="Wrap" />
                </StackPanel>

                <StackPanel
                    Grid.Column="1"
                    HorizontalAlignment="Right"
                    Orientation="Horizontal"
                    Spacing="10">
                    <Button Classes="feil-ghost" Command="{Binding ResetDefaultsCommand}">
                        <TextBlock FontSize="13" Text="Reset Defaults" />
                    </Button>
                    <Button Classes="feil-accent" Command="{Binding SaveCommand}">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <PathIcon
                                Width="14"
                                Height="14"
                                Data="M17 3H5c-1.11 0-2 .9-2 2v14c0 1.1.89 2 2 2h14c1.1 0 2-.9 2-2V7l-4-4zm-5 16c-1.66 0-3-1.34-3-3s1.34-3 3-3 3 1.34 3 3-1.34 3-3 3zm3-10H5V5h10v4z"
                                Foreground="White" />
                            <TextBlock
                                FontSize="13"
                                FontWeight="SemiBold"
                                Text="Save Settings" />
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>

        </StackPanel>
    </ScrollViewer>

</UserControl>
