<UserControl
    x:Class="Feil.Views.Pages.HistoryPage"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:evm="using:Feil.ViewModels"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="using:Feil.ViewModels.Pages"
    x:DataType="vm:HistoryPageViewModel"
    Background="Transparent"
    mc:Ignorable="d">

    <Grid RowDefinitions="Auto,*">

        <!--  ── PAGE HEADER ──  -->
        <StackPanel
            Grid.Row="0"
            Margin="28,24,28,16"
            Spacing="3">
            <TextBlock Classes="page-title" Text="History" />
            <TextBlock Classes="page-subtitle" Text="Past downloads and their outcomes" />
        </StackPanel>

        <!--  ── EMPTY STATE ──  -->
        <Border
            Grid.Row="1"
            Margin="28,0"
            Padding="48"
            Background="{DynamicResource FeilSurfaceRaised}"
            BorderBrush="{DynamicResource FeilBorder}"
            BorderThickness="1"
            CornerRadius="12"
            IsVisible="{Binding IsEmpty}">
            <StackPanel
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Spacing="14">
                <Border
                    Width="64"
                    Height="64"
                    HorizontalAlignment="Center"
                    Background="#10FFFFFF"
                    BorderBrush="{DynamicResource FeilBorder}"
                    BorderThickness="1"
                    CornerRadius="16">
                    <PathIcon
                        Width="28"
                        Height="28"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Data="M13 3a9 9 0 0 0-9 9H1l3.89 3.89.07.14L9 12H6c0-3.87 3.13-7 7-7s7 3.13 7 7-3.13 7-7 7c-1.93 0-3.68-.79-4.94-2.06l-1.42 1.42A8.954 8.954 0 0 0 13 21a9 9 0 0 0 0-18zm-1 5v5l4.28 2.54.72-1.21-3.5-2.08V8H12z"
                        Foreground="{DynamicResource FeilTextMuted}" />
                </Border>
                <StackPanel HorizontalAlignment="Center" Spacing="4">
                    <TextBlock
                        HorizontalAlignment="Center"
                        FontSize="16"
                        FontWeight="SemiBold"
                        Foreground="{DynamicResource FeilTextSecondary}"
                        Text="No history yet" />
                    <TextBlock
                        HorizontalAlignment="Center"
                        FontSize="13"
                        Foreground="{DynamicResource FeilTextMuted}"
                        Text="Completed downloads will appear here" />
                </StackPanel>
            </StackPanel>
        </Border>

        <!--  ── HISTORY LIST ──  -->
        <Grid
            Grid.Row="1"
            Margin="28,0,28,24"
            IsVisible="{Binding !IsEmpty}"
            RowDefinitions="*,Auto">

            <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto">
                <ItemsControl ItemsSource="{Binding Entries}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="evm:HistoryEntryViewModel">

                            <Border
                                Margin="0,0,0,6"
                                Padding="18,14"
                                Classes="feil-card">

                                <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="16">

                                    <!--  Game icon  -->
                                    <Border
                                        Grid.Column="0"
                                        Width="44"
                                        Height="44"
                                        VerticalAlignment="Center"
                                        Classes="game-icon">
                                        <Grid>
                                            <Image
                                                IsVisible="{Binding HasGameIcon}"
                                                Source="{Binding GameIcon}"
                                                Stretch="UniformToFill" />
                                            <PathIcon
                                                Width="14"
                                                Height="14"
                                                HorizontalAlignment="Center"
                                                VerticalAlignment="Center"
                                                Data="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 14.5v-9l6 4.5-6 4.5z"
                                                Foreground="{DynamicResource FeilTextMuted}"
                                                IsVisible="{Binding !HasGameIcon}" />
                                        </Grid>
                                    </Border>

                                    <!--  Game info  -->
                                    <StackPanel
                                        Grid.Column="1"
                                        VerticalAlignment="Center"
                                        Spacing="6">

                                        <TextBlock
                                            FontSize="14"
                                            FontWeight="SemiBold"
                                            Foreground="{DynamicResource FeilTextPrimary}"
                                            Text="{Binding GameName}"
                                            TextTrimming="CharacterEllipsis" />

                                        <!--  Metadata pills  -->
                                        <StackPanel Orientation="Horizontal" Spacing="5">

                                            <Border
                                                Padding="6,2"
                                                Background="{DynamicResource FeilSurface}"
                                                BorderBrush="{DynamicResource FeilBorder}"
                                                BorderThickness="1"
                                                CornerRadius="4">
                                                <TextBlock FontSize="11" Foreground="{DynamicResource FeilTextSecondary}">
                                                    <Run Text="App " />
                                                    <Run Text="{Binding AppId}" />
                                                </TextBlock>
                                            </Border>

                                            <Border
                                                Padding="6,2"
                                                Background="{DynamicResource FeilSurface}"
                                                BorderBrush="{DynamicResource FeilBorder}"
                                                BorderThickness="1"
                                                CornerRadius="4">
                                                <TextBlock FontSize="11" Foreground="{DynamicResource FeilTextSecondary}">
                                                    <Run Text="{Binding DepotCount}" />
                                                    <Run Text=" depots" />
                                                </TextBlock>
                                            </Border>

                                            <Border
                                                Padding="6,2"
                                                Background="{DynamicResource FeilSurface}"
                                                BorderBrush="{DynamicResource FeilBorder}"
                                                BorderThickness="1"
                                                CornerRadius="4">
                                                <TextBlock
                                                    FontSize="11"
                                                    Foreground="{DynamicResource FeilTextSecondary}"
                                                    Text="{Binding FormattedSize}" />
                                            </Border>

                                            <Border
                                                Padding="6,2"
                                                Background="{DynamicResource FeilSurface}"
                                                BorderBrush="{DynamicResource FeilBorder}"
                                                BorderThickness="1"
                                                CornerRadius="4">
                                                <TextBlock
                                                    FontSize="11"
                                                    Foreground="{DynamicResource FeilTextSecondary}"
                                                    Text="{Binding FormattedDuration}" />
                                            </Border>

                                        </StackPanel>
                                    </StackPanel>

                                    <!--  Date + status + options  -->
                                    <StackPanel
                                        Grid.Column="2"
                                        HorizontalAlignment="Right"
                                        VerticalAlignment="Center"
                                        Spacing="6">

                                        <TextBlock
                                            HorizontalAlignment="Right"
                                            FontSize="11"
                                            Foreground="{DynamicResource FeilTextMuted}"
                                            Text="{Binding FormattedDate}" />

                                        <StackPanel
                                            HorizontalAlignment="Right"
                                            VerticalAlignment="Center"
                                            Orientation="Horizontal"
                                            Spacing="6">

                                            <Border Classes="badge-success" IsVisible="{Binding IsSuccess}">
                                                <TextBlock Foreground="{DynamicResource FeilSuccessBrush}" Text="COMPLETED" />
                                            </Border>
                                            <Border Classes="badge-failed" IsVisible="{Binding IsFailed}">
                                                <TextBlock Foreground="{DynamicResource FeilDangerBrush}" Text="FAILED" />
                                            </Border>
                                            <Border Classes="badge-cancelled" IsVisible="{Binding IsCancelled}">
                                                <TextBlock Foreground="{DynamicResource FeilCancelledBrush}" Text="CANCELLED" />
                                            </Border>

                                            <!--  Options Menu  -->
                                            <Button Classes="feil-icon" ToolTip.Tip="More options">
                                                <Button.Flyout>
                                                    <MenuFlyout Placement="BottomEdgeAlignedRight">
                                                        <MenuItem
                                                            Command="{Binding $parent[UserControl].((vm:HistoryPageViewModel)DataContext).AddOnlineCommand}"
                                                            CommandParameter="{Binding}"
                                                            Header="Add Online"
                                                            IsVisible="{Binding IsSuccess}">
                                                            <MenuItem.Icon>
                                                                <PathIcon
                                                                    Width="14"
                                                                    Height="14"
                                                                    Data="M11.99 2C6.47 2 2 6.48 2 12s4.47 10 9.99 10C17.52 22 22 17.52 22 12S17.52 2 11.99 2zm6.93 6h-2.95c-.32-1.25-.78-2.45-1.38-3.56 1.84.63 3.37 1.91 4.33 3.56zM12 4.04c.83 1.2 1.48 2.53 1.91 3.96h-3.82c.43-1.43 1.08-2.76 1.91-3.96zM4.26 14C4.1 13.36 4 12.69 4 12s.1-1.36.26-2h3.38c-.08.66-.14 1.32-.14 2s.06 1.34.14 2H4.26zm.82 2h2.95c.32 1.25.78 2.45 1.38 3.56-1.84-.63-3.37-1.9-4.33-3.56zm2.95-8H5.08c.96-1.66 2.49-2.93 4.33-3.56C8.81 5.55 8.35 6.75 8.03 8zM12 19.96c-.83-1.2-1.48-2.53-1.91-3.96h3.82c-.43 1.43-1.08 2.76-1.91 3.96zM14.34 14H9.66c-.09-.66-.16-1.32-.16-2s.07-1.35.16-2h4.68c.09.65.16 1.32.16 2s-.07 1.34-.16 2zm.25 5.56c.6-1.11 1.06-2.31 1.38-3.56h2.95c-.96 1.65-2.49 2.93-4.33 3.56zM16.36 14c.08-.66.14-1.32.14-2s-.06-1.34-.14-2h3.38c.16.64.26 1.31.26 2s-.1 1.36-.26 2h-3.38z" />
                                                            </MenuItem.Icon>
                                                        </MenuItem>
                                                        <MenuItem
                                                            Command="{Binding $parent[UserControl].((vm:HistoryPageViewModel)DataContext).RemoveEntryCommand}"
                                                            CommandParameter="{Binding}"
                                                            Header="Remove">
                                                            <MenuItem.Icon>
                                                                <PathIcon
                                                                    Width="14"
                                                                    Height="14"
                                                                    Data="M6 19c0 1.1.9 2 2 2h8c1.1 0 2-.9 2-2V7H6v12zM19 4h-3.5l-1-1h-5l-1 1H5v2h14V4z" />
                                                            </MenuItem.Icon>
                                                        </MenuItem>
                                                        <MenuItem
                                                            Command="{Binding $parent[UserControl].((vm:HistoryPageViewModel)DataContext).VerifyCommand}"
                                                            CommandParameter="{Binding}"
                                                            Header="Reverify Files"
                                                            IsVisible="{Binding CanVerify}">
                                                            <MenuItem.Icon>
                                                                <PathIcon
                                                                    Width="14"
                                                                    Height="14"
                                                                    Data="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z" />
                                                            </MenuItem.Icon>
                                                        </MenuItem>
                                                        <MenuItem
                                                            Command="{Binding $parent[UserControl].((vm:HistoryPageViewModel)DataContext).RetryFailedCommand}"
                                                            CommandParameter="{Binding}"
                                                            Header="Retry Download"
                                                            IsVisible="{Binding CanRetry}">
                                                            <MenuItem.Icon>
                                                                <PathIcon
                                                                    Width="14"
                                                                    Height="14"
                                                                    Data="M17.65 6.35C16.2 4.9 14.21 4 12 4c-4.42 0-7.99 3.58-7.99 8s3.57 8 7.99 8c3.73 0 6.84-2.55 7.73-6h-2.08c-.82 2.33-3.04 4-5.65 4-3.31 0-6-2.69-6-6s2.69-6 6-6c1.66 0 3.14.69 4.22 1.78L13 11h7V4l-2.35 2.35z" />
                                                            </MenuItem.Icon>
                                                        </MenuItem>
                                                        <MenuItem
                                                            Command="{Binding $parent[UserControl].((vm:HistoryPageViewModel)DataContext).GenerateAchievementsCommand}"
                                                            CommandParameter="{Binding}"
                                                            Header="Generate Achievements"
                                                            IsVisible="{Binding IsSuccess}">
                                                            <MenuItem.Icon>
                                                                <PathIcon
                                                                    Width="14"
                                                                    Height="14"
                                                                    Data="M19 5h-2V3H7v2H5c-1.1 0-2 .9-2 2v1c0 2.55 1.92 4.63 4.39 4.94.63 1.5 1.98 2.63 3.61 2.96V19H7v2h10v-2h-4v-3.1c1.63-.33 2.98-1.46 3.61-2.96C19.08 12.63 21 10.55 21 8V7c0-1.1-.9-2-2-2zM5 8V7h2v3.82C5.84 10.4 5 9.3 5 8zm14 0c0 1.3-.84 2.4-2 2.82V7h2v1z" />
                                                            </MenuItem.Icon>
                                                        </MenuItem>
                                                    </MenuFlyout>
                                                </Button.Flyout>
                                                <PathIcon
                                                    Width="13"
                                                    Height="13"
                                                    Data="M12 8c1.1 0 2-.9 2-2s-.9-2-2-2-2 .9-2 2 .9 2 2 2zm0 2c-1.1 0-2 .9-2 2s.9 2 2 2 2-.9 2-2-.9-2-2-2zm0 6c-1.1 0-2 .9-2 2s.9 2 2 2 2-.9 2-2-.9-2-2-2z"
                                                    Foreground="{DynamicResource FeilTextMuted}" />
                                            </Button>

                                        </StackPanel>
                                    </StackPanel>

                                </Grid>
                            </Border>

                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

            <!--  ── CLEAR HISTORY ──  -->
            <Border Grid.Row="1" Padding="0,10,0,0">
                <Button
                    HorizontalAlignment="Right"
                    Classes="feil-danger"
                    Command="{Binding ClearHistoryCommand}">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <PathIcon
                            Width="14"
                            Height="14"
                            Data="M6 19c0 1.1.9 2 2 2h8c1.1 0 2-.9 2-2V7H6v12zM19 4h-3.5l-1-1h-5l-1 1H5v2h14V4z" />
                        <TextBlock FontSize="13" Text="Clear History" />
                    </StackPanel>
                </Button>
            </Border>

        </Grid>

    </Grid>

</UserControl>
